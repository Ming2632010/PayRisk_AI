# From Neon: Connection string (Neon Console → Connection details)
NEON_DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Auth: long random string for signing JWTs (e.g. run: openssl rand -base64 32)
AUTH_JWT_SECRET=your-secret-at-least-32-chars

PORT=3001

# Public URL of the web app (used in Stripe success/cancel redirects and password-reset links).
# Production example: https://payriskai.com  (no trailing slash required)
# FRONTEND_URL=https://payriskai.com

# Stripe recurring subscriptions (Basic / Professional / Business)
# STRIPE_SECRET_KEY=sk_live_xxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxx
# Webhook URL: https://your-api.onrender.com/api/webhooks/stripe
# Enable events: checkout.session.completed, invoice.paid, invoice.upcoming,
#   customer.subscription.updated, customer.subscription.deleted
# In Stripe Dashboard → Settings → Billing → Customer portal: enable portal for payment method / cancel.

# Optional: Email (Resend)
# RESEND_API_KEY=re_xxxx
# FROM_EMAIL=onboarding@resend.dev
# FROM_EMAIL must be a domain you verified in Resend. Reply-To: invoice template email when set and valid, else account email (reminder, offer, invoice).

# Optional: SMS (Twilio) – for Send SMS (one-way reminders).
# Required: ACCOUNT_SID and AUTH_TOKEN.
# Plus either MESSAGING_SERVICE_SID (preferred — auto-picks sender per country) or PHONE_NUMBER.
# Set MESSAGING_SERVICE_SID when you want to use Alphanumeric Sender ID (branded sender name,
# e.g. "ACME") in AU / UK / most of EU / APAC, and/or a pool of numbers for US / Canada.
# TWILIO_ACCOUNT_SID=ACxxxx
# TWILIO_AUTH_TOKEN=xxxx
# TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_PHONE_NUMBER=+1234567890
