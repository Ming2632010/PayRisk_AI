{
  "redirects": [
    {
      "source": "/privacy",
      "destination": "/privacy.html",
      "permanent": false
    },
    {
      "source": "/terms",
      "destination": "/terms.html",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/((?!business\\.html|privacy\\.html|terms\\.html|sms-opt-in\\.html).*)",
      "destination": "/index.html"
    }
  ]
}
